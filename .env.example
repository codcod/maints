# See docs/ for which variables each command needs. JIRA_URL alone is enough for `maints open`.

# Optional: override the maints config directory (triage + serve; default: ~/.config/maints)
# MAINTS_HOME=

# Jira Configuration
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# Required for `maints dig` (no defaults — set explicitly)
JIRA_TEAM_FIELD=
JIRA_TEAM_ID=

# Optional for `maints dig`
# JIRA_DIG_ISSUE_TYPE=Bug
# JIRA_LINK_TYPE=Solved by
# JIRA_SOLVES_LINK_TYPE=

# Cursor Agent (maints triage, maints serve) — not used by maints dig
# https://cursor.com/dashboard?tab=integrations
CURSOR_API_KEY=your-cursor-api-key
